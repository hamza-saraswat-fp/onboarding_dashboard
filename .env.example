# Copy to .env.local and fill in. Real values are never committed.

# Read-only connection to the onboarding app's Supabase (use a read-only role).
DATABASE_URL=

# Base URL of the onboarding wizard app, used to reconstruct the link each
# customer opened: `${ONBOARDING_APP_URL}/setup?token=<access_token>`. Optional;
# defaults to https://welcome.fieldpulse.com.
ONBOARDING_APP_URL=

# Extra test accounts to hide from all stats (comma-separated company ids), for
# test accounts the name heuristic ("test"/"e2e") can't catch. Optional.
TEST_COMPANY_IDS=

# Real Salesforce accounts that should not count in the numbers (comma-separated
# company ids): a link generated on an existing account, or one never actually
# sent. Distinct from test accounts. Primary curation is the array in
# lib/hidden-accounts.ts; this is a no-deploy escape hatch. Optional.
HIDDEN_COMPANY_IDS=

# --- Active gate: Google SSO + email allowlist ---
# Generate a secret with: npx auth secret
AUTH_SECRET=
# Google OAuth client credentials (Google Cloud console, Web application).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Plain (NOT secret) comma-separated allowlist. An entry starting with "@"
# matches a whole domain (e.g. @fieldpulse.com); any other entry must match the
# full email. Case-insensitive. Empty denies everyone.
ALLOWED_EMAILS=@fieldpulse.com
# Local dev only: "true" bypasses Google SSO with a stub user. Ignored when
# NODE_ENV=production; never set this in Vercel.
AUTH_DEV_BYPASS=

# --- Dormant fallback: shared HTTP Basic Auth ---
# Not used while the Google SSO middleware is active. To fall back to a shared
# username + password, restore the Basic Auth middleware in middleware.ts and
# set these. Deny-by-default: if either is empty, no one gets in.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
