# Copy to .env.local and fill in. Real values are never committed.

# Read-only connection to the onboarding app's Supabase (use a read-only role).
DATABASE_URL=

# Base URL of the onboarding wizard app, used to reconstruct the link each
# customer opened: `${ONBOARDING_APP_URL}/setup?token=<access_token>`. Optional;
# defaults to https://welcome.fieldpulse.com.
ONBOARDING_APP_URL=

# --- Active gate: HTTP Basic Auth (quick launch) ---
# Shared username + password that protects every route. Deny-by-default: if
# either is empty, no one gets in.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Deferred: Google SSO path (not active in the quick launch) ---
# To switch the gate back to Google SSO, set these and restore the Auth.js
# middleware in middleware.ts.
# Generate a secret with: npx auth secret
AUTH_SECRET=
# Google OAuth client credentials (Google Cloud console).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Local dev only for the SSO path: "true" bypasses Google SSO with a stub user.
# Ignored when NODE_ENV=production.
AUTH_DEV_BYPASS=
# Plain (NOT secret) comma-separated allowlist of FieldPulse emails for the SSO
# path. Case-insensitive.
ALLOWED_EMAILS=
